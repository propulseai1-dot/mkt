# ============================================================
# SilkGenesis — variables pour Docker Compose + API (prod Tor)
# Copier vers .env a la racine du depot :
#   cp env.example .env
# Puis editer les valeurs (jamais committer .env).
# ============================================================

# --- Obligatoire en production (API refuse de demarrer sinon) ---
SILKGENESIS_ENV=production
# URL exacte du site (Tor Browser envoie Origin: http://xxxxx.onion)
SILKGENESIS_ALLOWED_ORIGINS=http://REMPLACEZ_PAR_VOTRE_HOSTNAME.onion
# Mot de passe bootstrap du compte admin (argon2 en memoire au premier boot)
SILKGENESIS_BOOTSTRAP_ADMIN_PASSWORD=REMPLACEZ_MOT_DE_PASSE_LONG_ET_ALEATOIRE

# --- Monero wallet-rpc (doit correspondre au service monero-rpc du compose) ---
MONERO_RPC_USER=silkgenesis_rpc
MONERO_RPC_PASS=REMPLACEZ_RPC_SECRET_LONG

# Optionnel : repertoire de persistance dans le conteneur API (defaut /app/data via Dockerfile)
# SILKGENESIS_DATA_DIR=/app/data

# Optionnel : chemin SQLite explicite (sinon <SILKGENESIS_DATA_DIR>/silkgenesis_data.db)
# SILKGENESIS_DB_PATH=/app/data/silkgenesis_data.db

# Noeud Monero pour le wallet-rpc Docker (local par defaut pour eviter tout leak clearnet)
MONERO_DAEMON_ADDRESS=127.0.0.1:18081

# --- Internal price oracle (temps reel) ---
# API lit ce endpoint interne seulement (pas d'appel clearnet direct depuis l'API)
PRICE_ORACLE_URL=http://price-oracle:9000/latest
# Token optionnel pour proteger /latest (mettre la meme valeur dans API et oracle)
PRICE_ORACLE_TOKEN=
# Refresh interval de l'oracle (secondes)
PRICE_ORACLE_REFRESH_SEC=20
# L'oracle peut sortir vers internet pour collecter les prix (1=oui, 0=non)
PRICE_ORACLE_ALLOW_CLEARNET=1
# Fallback local si upstream indisponible
PRICE_ORACLE_FALLBACK_XMR_USD=165.0
PRICE_ORACLE_FALLBACK_BTC_USD=74000.0
