# ============================================================
# SilkGenesis — STAGING / LOCAL
# Copier vers .env.staging (ne pas committer vos secrets).
# ============================================================

# En staging/local, l'API ne bloque pas sur des origins .onion.
SILKGENESIS_ENV=development
SILKGENESIS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Mot de passe bootstrap admin (utilise au 1er boot si aucun admin n'existe)
SILKGENESIS_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM

# Secret "pepper" applique aux hash (optionnel mais recommande)
SILKGENESIS_PEPPER=CHANGE_ME_PEPPER

# --- Monero ---
# En staging/local, tu peux laisser l'API demarrer meme si wallet-rpc n'est pas la.
# Si tu as un wallet-rpc en face, indique son URL.
MONERO_RPC_URL=http://127.0.0.1:18082/json_rpc
MONERO_RPC_USER=
MONERO_RPC_PASS=

# --- Price oracle ---
PRICE_ORACLE_URL=http://price-oracle:9000/latest
PRICE_ORACLE_TOKEN=
PRICE_ORACLE_REFRESH_SEC=20
PRICE_ORACLE_ALLOW_CLEARNET=1
PRICE_ORACLE_FALLBACK_XMR_USD=165.0
PRICE_ORACLE_FALLBACK_BTC_USD=74000.0

